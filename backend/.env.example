# Runtime and CORS
FRONTEND_ORIGIN=http://localhost:5173
SCRAPE_INTERVAL_SECONDS=300
SCRAPE_REQUEST_TIMEOUT=30
SCRAPE_REQUEST_DELAY=0.15
AUTO_SCRAPE=true
SCRAPE_ON_STARTUP=true
ENABLE_HUAWEI=true
ENABLE_KEHUA=true

# Supabase server-side storage. Never expose SUPABASE_SECRET_KEY to the frontend.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Must be sb_secret_... or a legacy service_role JWT; never use sb_publishable_.../anon.
SUPABASE_SECRET_KEY=replace-with-supabase-secret-or-service-role-key
SUPABASE_CURRENT_TABLE=monitoring_current
SUPABASE_HISTORY_TABLE=monitoring_snapshots
HISTORY_INTERVAL_SECONDS=3600
HISTORY_RETENTION_DAYS=30

# Huawei can refresh its session with credentials when the cookie is stale.
HUAWEI_USERNAME=replace-me
HUAWEI_PASSWORD=replace-me

# Paste each complete JSON cookie export on one line in Render's environment editor.
HUAWEI_COOKIES_JSON=[]
KEHUA_COOKIES_JSON=[]
